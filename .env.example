# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Twitter/X credentials (used only by setup_session.py)
TWITTER_USERNAME=your_twitter_email_or_handle
TWITTER_PASSWORD=your_twitter_password

# Paths
SESSION_FILE=session/twitter_auth.json

# Schedule (24h format, comma-separated, local timezone)
SCHEDULE_TIMES=08:00,18:00
TIMEZONE=America/New_York
